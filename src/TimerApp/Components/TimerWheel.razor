@namespace TimerApp.Components
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject ITimerService TimerService
@using TimerApp.Services

<div class="timer-wheel-container">
     <svg 
         class="timer-wheel" 
         viewBox="0 0 200 200"
         @ref="wheelElement"
         @onpointerdown="OnPointerDown"
         @onpointermove="OnPointerMove"
         @onpointerup="OnPointerUp"
         @onpointerleave="OnPointerLeave"
         @onkeydown="OnKeyDown"
         tabindex="0"
         touch-action="none"
         role="slider"
         aria-label="Timer wheel. Drag to adjust or use arrow keys."
         aria-valuemin="0"
         aria-valuemax="@TimerService.MaxSeconds"
         aria-valuenow="@TotalSeconds"
         aria-valuetext="@FormatAriaValueText(TotalSeconds)"
     >
        <circle class="track" cx="100" cy="100" r="80" />
        
        <circle 
            class="progress" 
            cx="100" 
            cy="100" 
            r="80"
            stroke-dasharray="@StrokeDashArray"
            stroke-dashoffset="@StrokeDashOffset"
            transform="rotate(-90 100 100)"
        />

        @for (int i = 0; i < TickCount; i++)
        {
            var angle = i * 6;
            var isLongTick = i % 10 == 0;
            <line 
                x1="100" 
                y1="25" 
                x2="100" 
                y2="@(isLongTick ? 32 : 28)"
                transform="rotate(@angle 100 100)"
                class="tick @(isLongTick ? "long" : "short")"
            />
        }

        @if (Rotations > 0)
        {
            <g class="rotation-badge">
                <rect x="140" y="20" width="45" height="24" rx="12" />
                <text x="162.5" y="36">+@(Rotations)h</text>
            </g>
        }
    </svg>
</div>

<fieldset class="keyboard-hint">
    <legend>Keyboard controls</legend>
    <button class="btn-mini" @onclick="() => AdjustSeconds(-1)" aria-label="Decrease time by dynamic step (keyboard: arrow left/down)" disabled="@(TotalSeconds == 0 || IsRunning)">-1</button>
    <button class="btn-mini" @onclick="() => AdjustSeconds(1)" aria-label="Increase time by dynamic step (keyboard: arrow right/up)" disabled="@(TotalSeconds >= TimerService.MaxSeconds || IsRunning)">+1</button>
</fieldset>

@code {
    private const double Radius = 80;
    private const double Circumference = 2 * Math.PI * Radius;
    private const int ThresholdSeconds = 300;
    private const int TickCount = 60;
    private const double DegreesPerRotation = 360.0;

    private ElementReference wheelElement;
    private bool isDragging;
    private double? startAngle;
    private double _accumulatedDelta;

    [Parameter]
    public int TotalSeconds { get; set; }

    [Parameter]
    public int CurrentRotationSeconds { get; set; }

    [Parameter]
    public int Rotations { get; set; }

    [Parameter]
    public bool IsRunning { get; set; }

    [Parameter]
    public Action<int>? OnSecondsChanged { get; set; }

    private string StrokeDashArray => $"{Circumference}";
    private string StrokeDashOffset
    {
        get
        {
            var progress = CurrentRotationSeconds / (double)TimerService.SecondsPerRotation;
            return $"{Circumference * (1 - progress)}";
        }
    }

    private async void OnPointerDown(PointerEventArgs e)
    {
        if (IsRunning) return;
        isDragging = true;
        startAngle = await GetAngleAsync(e);
    }

    private async void OnPointerMove(PointerEventArgs e)
    {
        if (!isDragging || !startAngle.HasValue || IsRunning) return;

        var currentAngle = await GetAngleAsync(e);
        var deltaAngle = NormalizeAngleDelta(currentAngle - startAngle.Value);
        _accumulatedDelta += deltaAngle;
        startAngle = currentAngle;

        var direction = Math.Sign(_accumulatedDelta);
        if (direction == 0)
        {
            return;
        }

        var nextSeconds = TotalSeconds;
        var changed = false;

        while (true)
        {
            var stepSizeInSeconds = nextSeconds >= ThresholdSeconds ? 60 : 1;
            var degreesPerStep = (DegreesPerRotation / TimerService.SecondsPerRotation) * stepSizeInSeconds;

            if (Math.Abs(_accumulatedDelta) < degreesPerStep)
            {
                break;
            }

            var candidateSeconds = Math.Clamp(nextSeconds + (direction * stepSizeInSeconds), 0, TimerService.MaxSeconds);
            if (candidateSeconds == nextSeconds)
            {
                _accumulatedDelta = 0;
                break;
            }

            nextSeconds = candidateSeconds;
            changed = true;
            _accumulatedDelta -= direction * degreesPerStep;
            direction = Math.Sign(_accumulatedDelta);

            if (direction == 0)
            {
                break;
            }
        }

        if (changed)
        {
            OnSecondsChanged?.Invoke(nextSeconds);
        }
    }

    private double NormalizeAngleDelta(double delta)
    {
        while (delta > 180) delta -= 360;
        while (delta < -180) delta += 360;
        return delta;
    }

    private void OnPointerUp(PointerEventArgs e)
    {
        isDragging = false;
        startAngle = null;
        _accumulatedDelta = 0;
    }

    private void OnPointerLeave(PointerEventArgs e)
    {
        isDragging = false;
        startAngle = null;
        _accumulatedDelta = 0;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (IsRunning) return;
        
        if (e.Key == "ArrowUp" || e.Key == "ArrowRight")
        {
            AdjustSeconds(1);
        }
        else if (e.Key == "ArrowDown" || e.Key == "ArrowLeft")
        {
            AdjustSeconds(-1);
        }
    }

    private void AdjustSeconds(int direction)
    {
        if (IsRunning) return;

        var stepSizeInSeconds = TotalSeconds >= ThresholdSeconds ? 60 : 1;
        var newSeconds = Math.Clamp(TotalSeconds + (direction * stepSizeInSeconds), 0, TimerService.MaxSeconds);

        if (newSeconds != TotalSeconds)
        {
            OnSecondsChanged?.Invoke(newSeconds);
        }
    }

    private static string FormatAriaValueText(int totalSeconds)
    {
        if (totalSeconds <= 0)
        {
            return "0 minutes";
        }

        if (totalSeconds < ThresholdSeconds)
        {
            return $"{totalSeconds / 60} minutes {totalSeconds % 60} seconds";
        }

        return $"{totalSeconds / 60} minutes";
    }

    private async Task<double> GetAngleAsync(PointerEventArgs e)
    {
        var rect = await JS.InvokeAsync<BoundingRect>("getBoundingClientRect", wheelElement);
        var centerX = rect.Left + rect.Width / 2;
        var centerY = rect.Top + rect.Height / 2;
        
        var x = e.ClientX - centerX;
        var y = e.ClientY - centerY;
        
        var angle = Math.Atan2(y, x) * 180 / Math.PI;
        if (angle < 0) angle += 360;
        
        return angle;
    }

    private class BoundingRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        await Task.CompletedTask;
    }
}
